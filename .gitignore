# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg

# Virtual environments
.env
.venv/
env/
venv/
ENV/

# Testing / coverage
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/

# Jupyter
.ipynb_checkpoints/

# Editors / IDEs
.vscode/
.idea/

# OS artifacts
.DS_Store
Thumbs.db

# Model artifacts
*.pkl
*.joblib
*.h5

# Project data and generated outputs (regenerated locally, not tracked)
data/raw/*
!data/raw/.gitkeep
outputs/*
!outputs/.gitkeep
